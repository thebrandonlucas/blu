# Generic loop configuration
#
# Setup:
# 1. Pick a way to run your coding agent from the shell.
# 2. Set LOOP_AGENT_RUNNER to a command or wrapper script.
# 3. The runner receives these env vars:
#      LOOP_ROLE
#      LOOP_PHASE
#      LOOP_PROMPT_FILE
#      LOOP_OUTPUT_FILE
#      LOOP_PROJECT_ROOT
# 4. The runner should write its result to $LOOP_OUTPUT_FILE.

LOOP_AGENT_RUNNER=
VERIFY_TEST_CMD=
VERIFY_LINT_CMD=
VERIFY_TYPECHECK_CMD=
VERIFY_BUILD_CMD='bun run build'
